function WindowMethods:FindTab(name)
    local wanted = tostring(name)
    for _, tab in ipairs(self.Tabs) do
        if tab.Name == wanted then
            return tab
        end
    end
    return nil
end

function WindowMethods:SelectTab(tabOrName)
    local target = typeof(tabOrName) == "table" and tabOrName or self:FindTab(tabOrName)
    if not target then
        return nil
    end

    self.SelectedTab = target

    for _, tab in ipairs(self.Tabs) do
        local selected = (tab == target)
        tab.Page.Visible = selected
        tab.NavButton.BackgroundColor3 = selected and DEFAULT_COLORS.NavSelected or DEFAULT_COLORS.NavIdle
        tab.NavButton.TextColor3 = selected and Color3.fromRGB(244, 244, 246) or DEFAULT_COLORS.TextMuted
    end

    if self.OnTabChanged then
        pcall(self.OnTabChanged, target)
    end

    return target
end

function WindowMethods:CreateTab(name, options)
    local opts = options or {}
    local tab = setmetatable({}, TabMethods)
    tab.Window = self
    tab.Name = tostring(name or ("tab" .. tostring(#self.Tabs + 1)))

    tab.Page = create("Frame", {
        Name = tab.Name .. "Page",
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
        Visible = false,
    }, self.ContentArea)

    local x = 228 + ((#self.Tabs) * 106)
    tab.NavButton = create("TextButton", {
        Size = UDim2.fromOffset(96, 40),
        Position = UDim2.fromOffset(x, 14),
        BackgroundColor3 = DEFAULT_COLORS.NavIdle,
        BorderSizePixel = 0,
        AutoButtonColor = false,
        Text = tab.Name,
        TextColor3 = DEFAULT_COLORS.TextMuted,
        TextSize = 13,
        Font = Enum.Font.GothamMedium,
    }, self.BottomBar)
    round(tab.NavButton, UDim.new(0, 8))

    tab.NavButton.MouseButton1Click:Connect(function()
        tab:Show()
    end)

    table.insert(self.Tabs, tab)

    if opts.Selected or #self.Tabs == 1 then
        self:SelectTab(tab)
    end

    return tab
end

function WindowMethods:Notify(title, text, duration, color)
    title = tostring(title or "Notification")
    text = tostring(text or "")
    duration = tonumber(duration) or 4

    local toast = create("Frame", {
        Size = UDim2.new(1, 0, 0, 62),
        BackgroundColor3 = DEFAULT_COLORS.Header,
        BorderSizePixel = 0,
    }, self.NotificationList)
    round(toast, UDim.new(0, 10))
    create("UIStroke", {
        Color = color or DEFAULT_COLORS.Divider,
        Thickness = 1,
        Transparency = 0.35,
    }, toast)

    local titleLabel = create("TextLabel", {
        Size = UDim2.new(1, -20, 0, 18),
        Position = UDim2.fromOffset(10, 8),
        BackgroundTransparency = 1,
        Text = title,
        TextColor3 = DEFAULT_COLORS.Text,
        TextSize = 14,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left,
    }, toast)

    local bodyLabel = create("TextLabel", {
        Size = UDim2.new(1, -20, 0, 28),
        Position = UDim2.fromOffset(10, 28),
        BackgroundTransparency = 1,
        Text = text,
        TextWrapped = true,
        TextColor3 = DEFAULT_COLORS.TextDim,
        TextSize = 13,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Top,
    }, toast)

    task.spawn(function()
        task.wait(duration)
        if toast and toast.Parent then
            toast:Destroy()
        end
    end)

    return {
        Instance = toast,
        Title = titleLabel,
        Body = bodyLabel,
    }
end

function WindowMethods:_registerViewerSource(widget)

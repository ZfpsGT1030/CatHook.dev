    function widget:RefreshPopupPosition()
        local abs = holder.AbsolutePosition
        popup.Position = UDim2.fromOffset(abs.X, abs.Y + holder.AbsoluteSize.Y + 4)
        popup.Size = UDim2.fromOffset(holder.AbsoluteSize.X, math.min(210, 12 + (#self.Options * 28)))
    end

    function widget:SetOpen(state)
        self:RefreshPopupPosition()
        popup.Visible = state and true or false
        return self
    end

    function widget:ToggleOpen()
        self:SetOpen(not popup.Visible)
        return self
    end

    function widget:_updateSummary()
        local values = self:GetValue()
        if #values == 0 then
            valueLabel.Text = opts.PlaceholderText or "none"
        elseif #values <= 2 then
            valueLabel.Text = table.concat(values, ", ")
        else
            valueLabel.Text = tostring(#values) .. " selected"
        end
    end

    function widget:GetValue()
        local values = {}
        for _, option in ipairs(self.Options) do
            if self.Selected[tostring(option)] then
                table.insert(values, tostring(option))
            end
        end
        return values
    end

    function widget:SetText(text)
        label.Text = tostring(text)
        self.DisplayName = tostring(text)
        return self
    end

    function widget:SetValue(values, silent)
        self.Selected = {}
        for _, value in ipairs(values or {}) do
            self.Selected[tostring(value)] = true
        end
        self:_updateSummary()

        if not silent then
            local current = self:GetValue()
            for _, callback in ipairs(self.ChangedCallbacks) do
                callback(current, self)
            end
        end

        self:Rebuild()
        return self
    end

    widget.Set = widget.SetValue

    function widget:SetOptions(newOptions)
        self.Options = shallowCopyArray(newOptions or {})
        self:Rebuild()
        return self
    end

    widget.Refresh = widget.SetOptions

    function widget:OnChanged(callback)
        table.insert(self.ChangedCallbacks, callback)
        return callback
    end

    function widget:GetConfigValue()
        return self:GetValue()
    end

    function widget:ApplyConfigValue(value)
        self:SetValue(value, true)
    end

    function widget:Rebuild()
        for _, child in ipairs(list:GetChildren()) do
            if child:IsA("TextButton") then
                child:Destroy()
            end
        end

        for _, option in ipairs(self.Options) do
            local text = tostring(option)
            local row = create("TextButton", {
                Size = UDim2.new(1, 0, 0, 24),
                BackgroundColor3 = DEFAULT_COLORS.Header,
                BorderSizePixel = 0,
                AutoButtonColor = false,
                Text = text,
                TextColor3 = DEFAULT_COLORS.TextDim,
                TextSize = 13,
                Font = Enum.Font.Gotham,
                TextXAlignment = Enum.TextXAlignment.Left,
                ZIndex = 61,
            }, list)
            round(row, UDim.new(0, 6))
            pad(row, {
                PaddingLeft = UDim.new(0, 8),
                PaddingRight = UDim.new(0, 26),
            })

            local mark = create("TextLabel", {
                Size = UDim2.fromOffset(14, 14),
                Position = UDim2.new(1, -18, 0.5, -7),
                BackgroundTransparency = 1,
                Text = widget.Selected[text] and "x" or "",
                TextColor3 = DEFAULT_COLORS.Text,
                TextSize = 12,
                Font = Enum.Font.GothamBold,
                ZIndex = 62,
            }, row)

            row.MouseButton1Click:Connect(function()
                widget.Selected[text] = not widget.Selected[text]
                widget:_updateSummary()
                mark.Text = widget.Selected[text] and "x" or ""
                local current = widget:GetValue()
                for _, callback in ipairs(widget.ChangedCallbacks) do
                    callback(current, widget)
                end
            end)
        end

        self:RefreshPopupPosition()
    end

    hitbox.MouseButton1Click:Connect(function()
        widget:ToggleOpen()
    end)

    if widget.Flag then
        self.Window:_registerFlag(widget.Flag, widget)
    end

    if opts.Callback then
        widget:OnChanged(opts.Callback)
    end

    widget:SetValue(default, true)
    return widget
end


function WindowMethods:_registerFlag(flag, widget)
    if not flag or flag == "" then
        return
    end
    self.FlagWidgets[flag] = widget
end

function WindowMethods:SetFlag(flag, value, silent)
    local widget = self.FlagWidgets[flag]
    if widget and widget.SetValue then
        widget:SetValue(value, silent)
    end
    return self
end

function WindowMethods:GetFlag(flag)
    local widget = self.FlagWidgets[flag]
    if widget and widget.GetValue then
        return widget:GetValue()
    end
    return nil
end

function WindowMethods:GetFlagsSnapshot()
    local snapshot = {}
    for flag, widget in pairs(self.FlagWidgets) do
        if widget and widget.GetValue then
            snapshot[flag] = widget:GetValue()
        end
    end
    return snapshot
end

function WindowMethods:SetTitle(text)
    self.Title = tostring(text)
    if self.TitleLabel then
        self.TitleLabel.Text = self.Title
    end

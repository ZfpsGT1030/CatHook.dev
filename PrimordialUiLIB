            dragging = true
            dragStart = input.Position
            startPos = window.Main.Position
        end
    end))

    table.insert(window.Connections, header.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end))

    table.insert(window.Connections, UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            window.Main.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end))

    table.insert(window.Connections, UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then
            return
        end

        if window.ToggleKey and input.KeyCode == window.ToggleKey then
            window:Toggle()
        end

        for _, widget in ipairs(window.KeybindWidgets) do
            if widget.Capturing then
                if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode ~= Enum.KeyCode.Unknown then
                    widget.Capturing = false
                    widget:SetValue(input.KeyCode, true)
                end
                window:RefreshKeybindViewer()
                return
            end
        end

        if input.UserInputType == Enum.UserInputType.Keyboard then
            for _, widget in ipairs(window.KeybindWidgets) do
                if widget:GetValue() == input.KeyCode then
                    widget:Trigger()
                    if widget:GetMode() == "Hold" then
                        widget:SetActive(true)
                    elseif widget:GetMode() == "Toggle" then
                        widget:SetActive(not widget:IsActive())
                    elseif widget:GetMode() == "Always" then
                        widget:SetActive(true)
                    end
                end
            end
        end
    end))

    table.insert(window.Connections, UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.Keyboard then
            for _, widget in ipairs(window.KeybindWidgets) do
                if widget:GetValue() == input.KeyCode and widget:GetMode() == "Hold" then
                    widget:SetActive(false)
                end
            end
        end
    end))

    table.insert(window.Connections, RunService.RenderStepped:Connect(function()
        for _, floating in ipairs(window.FloatingWidgets) do
            if floating and floating.Popup and floating.Popup.Visible and floating.RefreshPopupPosition then
                floating:RefreshPopupPosition()
            end
        end
    end))

    self.LastWindow = window
    return window
end

function CatHookUI:Notification(title, text, duration)
    if self.LastWindow then
        return self.LastWindow:Notify(title, text, duration)
    end
end

if getgenv then
    getgenv().CatHookUI = CatHookUI
end

if shared then
    shared.CatHookUI = CatHookUI
end

return CatHookUI

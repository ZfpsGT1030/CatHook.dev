function PanelMethods:CreateKeybind(options)
    local opts = type(options) == "table" and options or {}
    local defaultKey = opts.Default or opts.Key or Enum.KeyCode.RightShift
    local defaultMode = tostring(opts.Mode or "Hold")
    local validModes = {
        Hold = true,
        Toggle = true,
        Always = true,
    }
    if not validModes[defaultMode] then
        defaultMode = "Hold"
    end

    local holder = create("Frame", {
        Size = opts.Size or UDim2.fromOffset(220, 34),
        Position = opts.Position or UDim2.fromOffset(0, 0),
        BackgroundColor3 = opts.BackgroundColor3 or DEFAULT_COLORS.Input,
        BorderSizePixel = 0,
    }, self.Instance)
    round(holder, opts.CornerRadius or UDim.new(0, 7))

    local label = create("TextLabel", {
        Size = UDim2.new(1, -108, 1, 0),
        Position = UDim2.fromOffset(10, 0),
        BackgroundTransparency = 1,
        Text = tostring(opts.Text or "keybind"),
        TextColor3 = DEFAULT_COLORS.Text,
        TextSize = 14,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
    }, holder)

    local modeButton = create("TextButton", {
        Size = UDim2.fromOffset(46, 20),
        Position = UDim2.new(1, -94, 0.5, -10),
        BackgroundColor3 = DEFAULT_COLORS.Header,
        BorderSizePixel = 0,
        AutoButtonColor = false,
        Text = defaultMode,
        TextColor3 = DEFAULT_COLORS.TextDim,
        TextSize = 11,
        Font = Enum.Font.Gotham,
    }, holder)
    round(modeButton, UDim.new(0, 6))

    local bindButton = create("TextButton", {
        Size = UDim2.fromOffset(40, 20),
        Position = UDim2.new(1, -44, 0.5, -10),
        BackgroundColor3 = DEFAULT_COLORS.Header,
        BorderSizePixel = 0,
        AutoButtonColor = false,
        Text = typeof(defaultKey) == "EnumItem" and defaultKey.Name or tostring(defaultKey),
        TextColor3 = DEFAULT_COLORS.TextDim,
        TextSize = 11,
        Font = Enum.Font.Gotham,
    }, holder)
    round(bindButton, UDim.new(0, 6))

    local widget = attachCommonMethods({}, holder)
    widget.WidgetType = "Keybind"
    widget.Window = self.Window
    widget.Flag = opts.Flag
    widget.DisplayName = tostring(opts.Text or opts.DisplayName or opts.Flag or "keybind")
    widget.Label = label
    widget.ModeButton = modeButton
    widget.BindButton = bindButton
    widget.Value = defaultKey
    widget.Mode = defaultMode
    widget.Active = defaultMode == "Always"
    widget.Capturing = false
    widget.TriggeredCallbacks = {}
    widget.ChangedCallbacks = {}

    function widget:SetText(text)
        self.Label.Text = tostring(text)
        self.DisplayName = tostring(text)
        self.Window:RefreshKeybindViewer()
        return self
    end

    function widget:GetValue()
        return self.Value
    end

    function widget:SetValue(value, silent)
        if typeof(value) == "EnumItem" then
            self.Value = value
            self.BindButton.Text = value.Name
        elseif type(value) == "string" then
            local enum = Enum.KeyCode[value]
            if enum then
                self.Value = enum
                self.BindButton.Text = enum.Name
            end
        end

        if not silent then
            for _, callback in ipairs(self.ChangedCallbacks) do
                callback(self.Value, self)
            end
        end

        return self
    end

    widget.Set = widget.SetValue

    function widget:GetMode()
        return self.Mode
    end

    function widget:SetMode(mode, silent)
        local nextMode = tostring(mode or "Hold")
        if not validModes[nextMode] then
            nextMode = "Hold"
        end

        self.Mode = nextMode
        self.ModeButton.Text = nextMode

        if self.Mode == "Always" then
            self.Active = true
        elseif self.Mode == "Hold" then
            self.Active = false
        end

        if not silent then
            self.Window:RefreshKeybindViewer()
        end

        return self
    end

    function widget:IsActive()
        return self.Active == true
    end

    function widget:SetActive(state, silent)
        self.Active = state and true or false

        if not silent then
            for _, callback in ipairs(self.ChangedCallbacks) do
                callback(self.Active, self)
            end
        end

        self.Window:RefreshKeybindViewer()
        return self
    end

    function widget:Trigger()
        for _, callback in ipairs(self.TriggeredCallbacks) do
            callback(self.Value, self)
        end
        return self
    end

    function widget:OnTriggered(callback)
        table.insert(self.TriggeredCallbacks, callback)
        return callback
    end

    function widget:OnChanged(callback)
        table.insert(self.ChangedCallbacks, callback)
        return callback
    end

    function widget:GetConfigValue()
        return {
            Key = self.Value,
            Mode = self.Mode,
        }
    end

    function widget:ApplyConfigValue(value)
        if typeof(value) == "table" then
            self:SetValue(value.Key, true)
            self:SetMode(value.Mode, true)
        else
            self:SetValue(value, true)
        end
    end

    modeButton.MouseButton1Click:Connect(function()
        if widget.Mode == "Hold" then
            widget:SetMode("Toggle")
        elseif widget.Mode == "Toggle" then
            widget:SetMode("Always")
            widget:SetActive(true)
        else
            widget:SetMode("Hold")
            widget:SetActive(false)
        end
    end)

    bindButton.MouseButton1Click:Connect(function()
        widget.Capturing = true
        widget.BindButton.Text = "..."
    end)

    if widget.Flag then
        self.Window:_registerFlag(widget.Flag, widget)
    end

    if opts.Viewer ~= false then
        self.Window:_registerViewerSource(widget)
    end

    if opts.Callback then
        widget:OnTriggered(opts.Callback)
    end

    self.Window.KeybindWidgets[#self.Window.KeybindWidgets + 1] = widget
    self.Window:RefreshKeybindViewer()
    return widget
end


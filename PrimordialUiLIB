local function create(className, props, parent)
    local object = Instance.new(className)
    for key, value in pairs(props or {}) do
        object[key] = value
    end
    object.Parent = parent
    return object
end

local function round(object, radius)
    create("UICorner", {
        CornerRadius = radius or UDim.new(0, 7),
    }, object)
    return object
end

local function pad(object, props)
    create("UIPadding", props, object)
    return object
end

local function tweenVisibility(instance, state)
    if instance then
        instance.Visible = state and true or false
    end
end

local function clamp(value, minimum, maximum)
    if value < minimum then
        return minimum
    end
    if value > maximum then
        return maximum
    end
    return value
end

local function roundToStep(value, step, minimum)
    if not step or step <= 0 then
        return value
    end
    minimum = minimum or 0
    return minimum + math.floor(((value - minimum) / step) + 0.5) * step
end

local function shallowCopyArray(list)
    local out = {}
    for i, value in ipairs(list or {}) do
        out[i] = value
    end
    return out
end

local function shallowCopyMap(map)
    local out = {}
    for key, value in pairs(map or {}) do
        out[key] = value
    end
    return out
end

local function splitPathName(path)
    local normalized = tostring(path or ""):gsub("\\", "/")
    local parts = string.split(normalized, "/")
    return parts[#parts] or normalized
end

local function attachCommonMethods(widget, instance)
    widget.Instance = instance

    function widget:GetInstance()
        return self.Instance
    end

    function widget:SetVisible(state)
        if self.Instance then
            self.Instance.Visible = state and true or false
        end
        return self
    end

    function widget:IsVisible()
        return self.Instance and self.Instance.Visible == true or false
    end

    function widget:Destroy()
        if self.OnDestroy then
            pcall(self.OnDestroy, self)
        end

        if self.Instance then
            self.Instance:Destroy()
            self.Instance = nil
        end
    end

    return widget
end

local function attachTextMethods(widget, instance)
    attachCommonMethods(widget, instance)

    function widget:SetText(text)
        if self.Instance then
            self.Instance.Text = tostring(text)
        end
        return self
    end

    function widget:GetText()
        if self.Instance then
            return self.Instance.Text
        end
        return ""
    end

    function widget:SetTextColor(color)
        if self.Instance then
            self.Instance.TextColor3 = color
        end
        return self
    end

    return widget
end

local function resolveParent(parentOverride)
    if parentOverride then
        return parentOverride
    end

    local ok, exploitUi = pcall(function()
        if gethui then
            return gethui()
        end
    end)

    if ok and exploitUi then
        return exploitUi
    end

    if LocalPlayer then
        local playerGui = LocalPlayer:FindFirstChildOfClass("PlayerGui") or LocalPlayer:WaitForChild("PlayerGui")
        if playerGui then
            return playerGui
        end
    end

    return game:GetService("CoreGui")
end

local function encodeValue(value)
    local valueType = typeof(value)

    if valueType == "Color3" then
        return {
            __type = "Color3",
            r = value.R,
            g = value.G,
            b = value.B,
        }
    elseif valueType == "EnumItem" then
        return {
            __type = "EnumItem",
            enumType = value.EnumType.Name,
            name = value.Name,
        }
    elseif valueType == "table" then
        local isArray = (#value > 0)
        if isArray then
            local array = {}
            for i, item in ipairs(value) do
                array[i] = encodeValue(item)
            end
            return {
                __type = "Array",
                items = array,
            }
        end

        local object = {}
        for key, item in pairs(value) do
            object[key] = encodeValue(item)
        end
        return {
            __type = "Table",
            items = object,
        }
    end

    return value
end

local function decodeValue(value)
    if typeof(value) ~= "table" or value.__type == nil then
        return value
    end

    if value.__type == "Color3" then
        return Color3.new(value.r or 0, value.g or 0, value.b or 0)
    elseif value.__type == "EnumItem" then
        local enumType = Enum[value.enumType]
        if enumType then
            for _, item in ipairs(enumType:GetEnumItems()) do
                if item.Name == value.name then
                    return item
                end
            end
        end
        return nil
    elseif value.__type == "Array" then
        local out = {}
        for i, item in ipairs(value.items or {}) do
            out[i] = decodeValue(item)
        end
        return out
    elseif value.__type == "Table" then
        local out = {}
        for key, item in pairs(value.items or {}) do
            out[key] = decodeValue(item)
        end
        return out
    end

    return value
end

local function filesystemAvailable()
    return type(writefile) == "function"
        and type(readfile) == "function"
        and type(isfile) == "function"
        and type(isfolder) == "function"
        and type(makefolder) == "function"
end

local function safeWrite(path, contents)
    return pcall(function()
        writefile(path, contents)
    end)
end

local function safeRead(path)
    local ok, result = pcall(function()
        return readfile(path)
    end)
    return ok, result
end

local function safeDelete(path)
    if type(delfile) ~= "function" then
        return false, "delfile unavailable"
    end
    return pcall(function()
        delfile(path)
    end)
end

local function safeListFiles(path)
    if type(listfiles) ~= "function" then
        return false, {}
    end

    local ok, result = pcall(function()
        return listfiles(path)
    end)
    if ok and type(result) == "table" then
        return true, result
    end

    return false, {}
end

local function ensureFolder(path)
    if not filesystemAvailable() then
        return false
    end

    local normalized = tostring(path or ""):gsub("\\", "/")
    local current = ""

    for _, piece in ipairs(string.split(normalized, "/")) do
        if piece ~= "" then
            current = current == "" and piece or (current .. "/" .. piece)
            if not isfolder(current) then
                makefolder(current)
            end
        end
    end

    return true
end


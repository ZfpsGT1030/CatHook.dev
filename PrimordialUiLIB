function PanelMethods:CreateSlider(options)
    local opts = type(options) == "table" and options or {}
    local minimum = tonumber(opts.Min or opts.Minimum or 0) or 0
    local maximum = tonumber(opts.Max or opts.Maximum or 100) or 100
    local defaultValue = tonumber(opts.Default or minimum) or minimum
    local decimals = tonumber(opts.Decimals or 0) or 0
    local step = tonumber(opts.Step or 0) or 0

    local holder = create("Frame", {
        Size = opts.Size or UDim2.fromOffset(220, 54),
        Position = opts.Position or UDim2.fromOffset(0, 0),
        BackgroundColor3 = opts.BackgroundColor3 or DEFAULT_COLORS.Input,
        BorderSizePixel = 0,
    }, self.Instance)
    round(holder, opts.CornerRadius or UDim.new(0, 8))

    local label = create("TextLabel", {
        Size = UDim2.new(1, -70, 0, 16),
        Position = UDim2.fromOffset(10, 8),
        BackgroundTransparency = 1,
        Text = tostring(opts.Text or "slider"),
        TextColor3 = DEFAULT_COLORS.Text,
        TextSize = 14,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Left,
    }, holder)

    local valueLabel = create("TextLabel", {
        Size = UDim2.fromOffset(50, 16),
        Position = UDim2.new(1, -60, 0, 8),
        BackgroundTransparency = 1,
        Text = "",
        TextColor3 = DEFAULT_COLORS.TextDim,
        TextSize = 13,
        Font = Enum.Font.Gotham,
        TextXAlignment = Enum.TextXAlignment.Right,
    }, holder)

    local bar = create("Frame", {
        Size = UDim2.new(1, -20, 0, 8),
        Position = UDim2.fromOffset(10, 32),
        BackgroundColor3 = Color3.fromRGB(22, 22, 23),
        BorderSizePixel = 0,
    }, holder)
    round(bar, UDim.new(1, 0))

    local fill = create("Frame", {
        Size = UDim2.new(0, 0, 1, 0),
        BackgroundColor3 = opts.FillColor or DEFAULT_COLORS.Divider,
        BorderSizePixel = 0,
    }, bar)
    round(fill, UDim.new(1, 0))

    local knob = create("Frame", {
        Size = UDim2.fromOffset(12, 12),
        Position = UDim2.new(0, -6, 0.5, -6),
        BackgroundColor3 = DEFAULT_COLORS.Text,
        BorderSizePixel = 0,
    }, bar)
    round(knob, UDim.new(1, 0))

    local widget = attachCommonMethods({}, holder)
    widget.WidgetType = "Slider"
    widget.Window = self.Window
    widget.Bar = bar
    widget.Fill = fill
    widget.Knob = knob
    widget.Label = label
    widget.ValueLabel = valueLabel
    widget.Min = minimum
    widget.Max = maximum
    widget.Decimals = decimals
    widget.Step = step
    widget.Flag = opts.Flag
    widget.DisplayName = tostring(opts.Text or opts.DisplayName or opts.Flag or "slider")
    widget.Value = defaultValue
    widget.ChangedCallbacks = {}
    widget.Dragging = false

    local function formatValue(value)
        if widget.Decimals <= 0 then
            return tostring(math.floor(value + 0.5))
        end
        return string.format("%." .. tostring(widget.Decimals) .. "f", value)
    end

    function widget:GetValue()
        return self.Value
    end

    function widget:SetText(text)
        self.Label.Text = tostring(text)
        self.DisplayName = tostring(text)
        return self
    end

    function widget:SetValue(value, silent)
        local number = tonumber(value) or self.Min
        number = clamp(number, self.Min, self.Max)
        if self.Step > 0 then
            number = roundToStep(number, self.Step, self.Min)
            number = clamp(number, self.Min, self.Max)
        end

        self.Value = number
        local alpha = (self.Value - self.Min) / math.max(self.Max - self.Min, 0.0001)
        self.Fill.Size = UDim2.new(alpha, 0, 1, 0)
        self.Knob.Position = UDim2.new(alpha, -6, 0.5, -6)
        self.ValueLabel.Text = formatValue(self.Value)

        if not silent then
            for _, callback in ipairs(self.ChangedCallbacks) do
                callback(self.Value, self)
            end
        end

        return self
    end

    widget.Set = widget.SetValue

    function widget:OnChanged(callback)
        table.insert(self.ChangedCallbacks, callback)
        return callback
    end

    function widget:GetConfigValue()
        return self:GetValue()
    end

    function widget:ApplyConfigValue(value)
        self:SetValue(value, true)
    end

    local function updateFromInput(input)
        local position = input.Position.X - widget.Bar.AbsolutePosition.X
        local alpha = clamp(position / math.max(widget.Bar.AbsoluteSize.X, 1), 0, 1)
        local raw = widget.Min + ((widget.Max - widget.Min) * alpha)
        widget:SetValue(raw)
    end

    bar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            widget.Dragging = true
            updateFromInput(input)
        end
    end)

    holder.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            local px = input.Position.X
            local left = bar.AbsolutePosition.X
            local right = left + bar.AbsoluteSize.X
            if px >= left and px <= right then
                widget.Dragging = true
                updateFromInput(input)
            end
        end
    end)

    table.insert(self.Window.Connections, UserInputService.InputChanged:Connect(function(input)
        if widget.Dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            updateFromInput(input)
        end
    end))

    table.insert(self.Window.Connections, UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            widget.Dragging = false
        end
    end))

    if widget.Flag then
        self.Window:_registerFlag(widget.Flag, widget)
    end

    if opts.Callback then
        widget:OnChanged(opts.Callback)
    end

    widget:SetValue(defaultValue, true)
    return widget
end


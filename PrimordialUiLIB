function WindowMethods:CreateKeybindViewer(options)
    local opts = options or {}

    if self.KeybindViewer and self.KeybindViewer.Instance and self.KeybindViewer.Instance.Parent then
        self.KeybindViewer:Destroy()
        self.KeybindViewer = nil
    end

    local frame = create("Frame", {
        Size = opts.Size or UDim2.fromOffset(220, 220),
        Position = opts.Position or UDim2.new(1, 18, 0, 64),
        BackgroundColor3 = DEFAULT_COLORS.Panel,
        BorderSizePixel = 0,
    }, self.Main)
    round(frame, UDim.new(0, 12))

    local titleLabel = create("TextLabel", {
        Size = UDim2.new(1, -20, 0, 24),
        Position = UDim2.fromOffset(10, 10),
        BackgroundTransparency = 1,
        Text = tostring(opts.Title or "active features"),
        TextColor3 = DEFAULT_COLORS.Text,
        TextSize = 15,
        Font = Enum.Font.GothamBold,
        TextXAlignment = Enum.TextXAlignment.Left,
    }, frame)

    local list = create("ScrollingFrame", {
        Size = UDim2.new(1, -20, 1, -46),
        Position = UDim2.fromOffset(10, 34),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        CanvasSize = UDim2.new(0, 0, 0, 0),
        AutomaticCanvasSize = Enum.AutomaticSize.Y,
        ScrollBarThickness = 3,
        ScrollBarImageColor3 = Color3.fromRGB(72, 72, 74),
    }, frame)

    local layout = create("UIListLayout", {
        Padding = UDim.new(0, 6),
        SortOrder = Enum.SortOrder.LayoutOrder,
    }, list)

    local viewer = attachCommonMethods({}, frame)
    viewer.TitleLabel = titleLabel
    viewer.List = list
    viewer.Layout = layout
    viewer.Items = {}
    viewer.Window = self

    function viewer:SetTitle(text)
        self.TitleLabel.Text = tostring(text)
        return self
    end

    function viewer:Refresh()
        for _, item in ipairs(self.Items) do
            if item and item.Parent then
                item:Destroy()
            end
        end
        table.clear(self.Items)

        local found = false

        for _, source in ipairs(self.Window.ViewerSources) do
            local text = nil

            if source.WidgetType == "Toggle" and source:GetValue() == true then
                text = tostring(source.DisplayName or source.Flag or "toggle") .. " [on]"
            elseif source.WidgetType == "Keybind" and source:IsActive() then
                text = tostring(source.DisplayName or source.Flag or "keybind") .. " [" .. tostring(source:GetMode()) .. "]"
            end

            if text then
                found = true
                local item = create("TextLabel", {
                    Size = UDim2.new(1, -2, 0, 26),
                    BackgroundColor3 = DEFAULT_COLORS.Header,
                    BorderSizePixel = 0,
                    Text = text,
                    TextColor3 = DEFAULT_COLORS.TextDim,
                    TextSize = 13,
                    Font = Enum.Font.Gotham,
                    TextXAlignment = Enum.TextXAlignment.Left,
                }, self.List)
                round(item, UDim.new(0, 8))
                pad(item, {
                    PaddingLeft = UDim.new(0, 10),
                    PaddingRight = UDim.new(0, 10),
                })
                table.insert(self.Items, item)
            end
        end

        if not found then
            local item = create("TextLabel", {
                Size = UDim2.new(1, -2, 0, 26),
                BackgroundColor3 = DEFAULT_COLORS.Header,
                BorderSizePixel = 0,
                Text = "no active features",
                TextColor3 = DEFAULT_COLORS.TextMuted,
                TextSize = 13,
                Font = Enum.Font.Gotham,
                TextXAlignment = Enum.TextXAlignment.Left,
            }, self.List)
            round(item, UDim.new(0, 8))
            pad(item, {
                PaddingLeft = UDim.new(0, 10),
                PaddingRight = UDim.new(0, 10),
            })
            table.insert(self.Items, item)
        end

        return self
    end

    self.KeybindViewer = viewer
    viewer:Refresh()
    return viewer
end

function WindowMethods:RefreshKeybindViewer()
    if self.KeybindViewer then
        self.KeybindViewer:Refresh()
    end
    return self
end

function WindowMethods:GetConfigFolder()
    return self.ConfigFolder
end

function WindowMethods:ExportConfigTable()
    local export = {
        __library = "CatHookUI",
        __version = CatHookUI.Version,
        flags = {},
    }

    for flag, widget in pairs(self.FlagWidgets) do
        if widget and widget.GetConfigValue then
            export.flags[flag] = encodeValue(widget:GetConfigValue())
        elseif widget and widget.GetValue then
            export.flags[flag] = encodeValue(widget:GetValue())
        end
    end

    return export
end

function WindowMethods:SaveConfig(name)
    if not filesystemAvailable() then
        self:Notify("config error", "filesystem functions are unavailable in this executor", 5, DEFAULT_COLORS.Error)
        return false, "filesystem unavailable"
    end

    local configName = tostring(name or "default")
    if configName == "" then
        configName = "default"
    end

    ensureFolder(self.ConfigFolder)

    local path = self.ConfigFolder .. "/" .. configName .. ".json"
    local payload = HttpService:JSONEncode(self:ExportConfigTable())
    local ok, err = safeWrite(path, payload)

    if ok then
        self:Notify("config saved", configName, 3, DEFAULT_COLORS.Success)
        return true, path
    end

    self:Notify("config error", tostring(err), 5, DEFAULT_COLORS.Error)
    return false, err
end

function WindowMethods:LoadConfig(name)
    if not filesystemAvailable() then
        self:Notify("config error", "filesystem functions are unavailable in this executor", 5, DEFAULT_COLORS.Error)
        return false, "filesystem unavailable"
    end

    local configName = tostring(name or "default")
    if configName == "" then
        configName = "default"
    end

    local path = self.ConfigFolder .. "/" .. configName .. ".json"
    if not isfile(path) then
        self:Notify("config error", "missing config: " .. configName, 5, DEFAULT_COLORS.Error)
        return false, "missing config"
    end

    local okRead, contents = safeRead(path)
    if not okRead then
        self:Notify("config error", tostring(contents), 5, DEFAULT_COLORS.Error)
        return false, contents
    end

    local okDecode, decoded = pcall(function()
        return HttpService:JSONDecode(contents)
    end)

    if not okDecode or type(decoded) ~= "table" then
        self:Notify("config error", "failed to decode config", 5, DEFAULT_COLORS.Error)
        return false, "decode failed"
    end

    for flag, encoded in pairs(decoded.flags or {}) do
        local widget = self.FlagWidgets[flag]
        if widget and widget.ApplyConfigValue then
            widget:ApplyConfigValue(decodeValue(encoded))
        elseif widget and widget.SetValue then
            widget:SetValue(decodeValue(encoded))
        end
    end

    self:RefreshKeybindViewer()
    self:Notify("config loaded", configName, 3, DEFAULT_COLORS.Success)
    return true, path
end

function WindowMethods:DeleteConfig(name)
    if not filesystemAvailable() then
        self:Notify("config error", "filesystem functions are unavailable in this executor", 5, DEFAULT_COLORS.Error)
        return false, "filesystem unavailable"
    end

    local configName = tostring(name or "default")
    local path = self.ConfigFolder .. "/" .. configName .. ".json"
    if not isfile(path) then
        self:Notify("config error", "missing config: " .. configName, 5, DEFAULT_COLORS.Error)
        return false, "missing config"
    end

    local ok, err = safeDelete(path)
    if ok then
        self:Notify("config deleted", configName, 3, DEFAULT_COLORS.Warning)
        return true, path
    end

    self:Notify("config error", tostring(err), 5, DEFAULT_COLORS.Error)
    return false, err
end

function WindowMethods:GetConfigNames()
    if not filesystemAvailable() then
        return {}
    end

    ensureFolder(self.ConfigFolder)

    local ok, paths = safeListFiles(self.ConfigFolder)
    if not ok then
        return {}
    end

    local names = {}
    for _, path in ipairs(paths) do
        local fileName = splitPathName(path)
        if string.sub(fileName, -5) == ".json" then
            table.insert(names, string.sub(fileName, 1, -6))
        end
    end
    table.sort(names)
    return names
end

function WindowMethods:Destroy()
    for _, connection in ipairs(self.Connections) do
        pcall(function()
            connection:Disconnect()
        end)
    end
    self.Connections = {}

    for _, popup in ipairs(self.FloatingWidgets) do
        if popup and popup.Parent then
            popup:Destroy()
        end
    end
    self.FloatingWidgets = {}

    if self.ScreenGui then
        self.ScreenGui:Destroy()
        self.ScreenGui = nil
    end
end

